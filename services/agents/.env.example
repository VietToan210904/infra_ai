# Future agent environment variables.
# Copy this file to services/agents/.env for local agent development.

AGENT_ENV=development
AGENT_LOG_LEVEL=info

# API endpoint used by future agent workflows.
INFRAAI_API_BASE_URL=http://localhost:8000

# LLM provider placeholders. Do not commit real keys.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# Optional future tracing/evaluation settings.
AGENT_TRACE_ENABLED=false
AGENT_EVAL_DATASET=
