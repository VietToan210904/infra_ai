# Public frontend environment variables.
# Copy these values into the repo-root .env for local frontend development.

# Public Mapbox browser token. Leave blank to use the demo fallback map.
VITE_MAPBOX_TOKEN=

# Optional FastAPI base URL. If the backend is unavailable, the frontend falls
# back to local deterministic mock functions.
VITE_API_BASE_URL=http://localhost:8000
