# Future FastAPI environment variables.
# Copy this file to apps/api/.env for local API development.

API_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
API_LOG_LEVEL=info

# Comma-separated browser origins allowed to call the API.
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Future database URL. Do not use real credentials in this example file.
DATABASE_URL=postgresql+psycopg://infraai:infraai@localhost:5432/infraai

# Future shared signing/config secret. Real values belong in local .env only.
API_SECRET_KEY=change-me-in-local-env
